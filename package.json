{
  "name": "vaexcore-pulse",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "bootstrap": "bash ./scripts/bootstrap.sh",
    "ci": "pnpm run lint && pnpm build:service-bundle && pnpm run check:service-bundle && pnpm run typecheck && pnpm test && pnpm run smoke:studio && (cd apps/desktopapp/src-tauri && cargo fmt --all -- --check && cargo clippy --all-targets -- -D warnings && cargo test) && pnpm run audit:maintainability && pnpm run budget:bundle",
    "check:env": "bash ./scripts/check-env.sh",
    "check:packages": "bash ./scripts/check-packages.sh",
    "dev:web": "bash ./scripts/dev-web.sh",
    "dev:desktop": "bash ./scripts/dev-desktop.sh",
    "dev:pulse": "bash ./scripts/dev-pulse.sh",
    "dev:mobile": "bash ./scripts/dev-mobile.sh",
    "dev:analyzer": "bash ./scripts/dev-analyzer.sh",
    "dev:api": "bash ./scripts/dev-api.sh",
    "dev:both": "bash ./scripts/dev-both.sh",
    "build:web": "pnpm --filter @vaexcore/pulse-webapp build",
    "build:desktop": "pnpm --filter @vaexcore/pulse-desktopapp build:desktop",
    "build:api": "pnpm --filter @vaexcore/pulse-api build",
    "build:service-bundle": "node scripts/build-service-bundle.mjs",
    "check:service-bundle": "node scripts/check-service-bundle.mjs",
    "app:build": "bash ./scripts/app-build.sh",
    "app:build:windows": "pnpm --filter @vaexcore/pulse-desktopapp exec tauri build --bundles nsis",
    "app:dist:windows": "pnpm app:build:windows",
    "app:zip": "bash ./scripts/app-zip.sh",
    "release:check": "bash ./scripts/release-check.sh",
    "release:unsigned": "bash ./scripts/release-unsigned.sh",
    "diagnostics": "bash ./scripts/diagnostics.sh",
    "smoke:studio": "pnpm exec tsx scripts/smoke-studio-integration.ts && pnpm run smoke:studio-handoff",
    "smoke:studio-handoff": "pnpm exec tsx scripts/smoke-studio-handoff-review-export.ts",
    "smoke:visual": "node scripts/visual-smoke.mjs",
    "test": "pnpm exec tsx --test packages/shared-types/src/mock.test.ts packages/domain/src/index.test.ts packages/export/src/index.test.ts services/api/src/app.test.ts",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "lint": "pnpm exec prettier --check .",
    "verify:web": "bash ./scripts/verify-web.sh",
    "verify:desktop": "bash ./scripts/verify-desktop.sh",
    "verify:mobile": "bash ./scripts/verify-mobile.sh",
    "verify:analyzer": "bash ./scripts/verify-analyzer.sh",
    "verify:api": "bash ./scripts/verify-api.sh",
    "verify:all": "bash ./scripts/verify-all.sh",
    "health": "bash ./scripts/doctor.sh",
    "doctor": "bash ./scripts/doctor.sh",
    "analyze:bundle": "node scripts/analyze-build.mjs",
    "budget:bundle": "node scripts/analyze-build.mjs --strict",
    "audit:maintainability": "node scripts/audit-maintainability.mjs --strict"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "esbuild": "0.28.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@vaexcore/pulse-domain": "workspace:*",
    "@vaexcore/pulse-export": "workspace:*",
    "@vaexcore/pulse-shared-types": "workspace:*"
  }
}
