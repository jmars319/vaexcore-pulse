{
  "name": "@vaexcore/pulse-desktopapp",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1 --port 1421",
    "build:service-bundle": "pnpm --dir ../.. build:service-bundle",
    "build:web": "tsc -p tsconfig.json && vite build",
    "build:desktop": "cargo check --manifest-path src-tauri/Cargo.toml && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "cargo check --manifest-path src-tauri/Cargo.toml && pnpm build:web"
  },
  "dependencies": {
    "@vaexcore/pulse-domain": "workspace:*",
    "@vaexcore/pulse-export": "workspace:*",
    "@vaexcore/pulse-media": "workspace:*",
    "@vaexcore/pulse-profiles": "workspace:*",
    "@vaexcore/pulse-scoring": "workspace:*",
    "@vaexcore/pulse-shared-types": "workspace:*",
    "@vaexcore/pulse-storage": "workspace:*",
    "@vaexcore/pulse-ui": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.0",
    "typescript": "5.9.3",
    "vite": "8.0.16"
  }
}
